NAKAMA_DB_DRIVER=postgres
# Prefer Nakama DSN format when passing CLI flags:
# postgres:<PASSWORD>@<HOST>:<PORT>/<DATABASE>
# Example:
NAKAMA_DB_ADDRESS=postgres:CHANGE_ME_PASSWORD@127.0.0.1:5432/nakama
NAKAMA_RUNTIME_PATH=./build
NAKAMA_LOGGER_LEVEL=INFO
NAKAMA_SESSION_TOKEN_EXPIRY_SEC=7200
NAKAMA_DB_DRIVER=postgres
NAKAMA_DB_ADDRESS=postgresql://postgres:123456@localhost:5432/nakama
NAKAMA_RUNTIME_PATH=./build
NAKAMA_LOGGER_LEVEL=DEBUG
NAKAMA_SESSION_TOKEN_EXPIRY_SEC=7200
NAKAMA_DB_DRIVER=postgres
NAKAMA_DB_ADDRESS=postgres:123456@127.0.0.1:5432/nakama?sslmode=disable
NAKAMA_RUNTIME_JS_ENTRYPOINT=D:/Assignments/tic-tac-toe/nakama/build/main.js
NAKAMA_LOGGER_LEVEL=INFO
NAKAMA_SESSION_TOKEN_EXPIRY_SEC=7200
